# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ── Supabase (server-only — used in lib/supabase.ts, never exposed to the browser) ──
# Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Project Settings → API → service_role key (NOT the anon key)
# This stays server-side only. Server Components / API routes can use it safely
# because it never ships in the client JS bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Formspree (server-only — used in app/api/contact/route.ts) ──
# Your form endpoint from https://formspree.io/forms
FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
